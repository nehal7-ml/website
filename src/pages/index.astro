---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import WorkExperience from '../components/WorkExperience.astro';
import Education from '../components/Education.astro';
import Projects from '../components/Projects.astro';
import HomeAvatar from '../components/HomeAvatar.astro';
import experience from '../data/expirence.json';
import avatar from '/public/avatar.png';
import Navbar from '../components/Navbar.astro';
import ContactButton from '../components/ContactButton.astro';
import ContactForm from '../components/ContactForm.astro';
import {
  getSecret,
 } from 'astro:env/server';


const ready =  getSecret('READY') ==="TRUE";
if(!ready) return Astro.rewrite('/coming-soon');

const web3formsAccessKey = getSecret('WEB3FORMS_ACCESS_KEY') || '';
---

<Layout title="Software Smith">
  <Navbar />
  <main>

    <section id="about" class="w-full flex flex-col md:flex-row justify-center items-center gap-10 lg:gap-16 md:px-6 mb-24 mt-12 scroll-mt-24">
      <div class="flex-shrink-0">
        <HomeAvatar image={"/avatar.png"} />
      </div>
      <div class="font-poppins flex flex-col items-center md:items-start text-center md:text-left">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight mb-4">
          The Software Smith!
        </h1>
        <p class="text-xl md:text-2xl lg:text-3xl font-bold text-slate-200 mb-6">
          I Can <span class="text-gradient-ember font-extrabold">Build Anything</span>.
        </p>
        <p class="text-base md:text-lg text-slate-300 max-w-xl leading-relaxed mb-8">
          Passionate Software Engineer with a focus on Web Development,
          dedicated to crafting elegant and user-friendly web applications and websites.
        </p>
        <ContactButton />
      </div>
    </section>

    <section class="flex flex-col items-start justify-center gap-8 mt-16 max-w-7xl mx-auto w-full px-4">
      <SectionHeader index="01" title="Work Experience" gradient="steel" />
      <div class="w-full max-w-3xl flex flex-col gap-6 self-center">
        {
          experience.map((experience) => (
            <WorkExperience
              title={experience.title}
              description={experience.description}
              startDate={experience.startDate}
              endDate={experience.endDate} 
            />
          ))
        }
      </div>
    </section>

    <Education />

    <Projects />


    <!-- Contact Section -->
    <section id="contact" class="flex flex-col items-start justify-center gap-8 mt-24 mb-16 scroll-mt-24 max-w-7xl mx-auto w-full px-4">
      <SectionHeader index="04" title="Contact Me" gradient="steel" />
      <p class="text-slate-200 max-w-2xl text-xl md:text-2xl leading-relaxed -mt-4">
        Have a project in mind or just want to say hi? Initiate a transmission below and let's discuss the build.
      </p>
      <div class="w-full">
        <ContactForm accessKey={web3formsAccessKey} />
      </div>
    </section>

	</main>
</Layout>

<style>
	main {
		margin: auto;
		padding: 1rem;
		width: 100%;
		max-width: calc(100% - 2rem);
		color: white;
		font-size: 20px;
		line-height: 1.6;
	}
	@media (min-width: 1024px) {
		main {
			width: 70%;
			max-width: 1400px;
		}
	}
	.astro-a {
		position: absolute;
		top: -32px;
		left: 50%;
		transform: translatex(-50%);
		width: 220px;
		height: auto;
		z-index: -1;
	}
	h1 {
		font-size: 4rem;
		font-weight: 700;
		line-height: 1;
		text-align: center;
		margin-bottom: 1em;
	}
  .text-gradient-steel {
    background-image: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 400%;
    background-position: 0%;
  }

  .text-gradient-ember {
    background-image: var(--accent-gradient-red);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 400%;
    background-position: 0%;
  }
	.instructions {
		margin-bottom: 2rem;
		border: 1px solid rgba(var(--accent-light), 25%);
		background: linear-gradient(rgba(var(--accent-dark), 66%), rgba(var(--accent-dark), 33%));
		padding: 1.5rem;
		border-radius: 8px;
	}
	.instructions code {
		font-size: 0.8em;
		font-weight: bold;
		background: rgba(var(--accent-light), 12%);
		color: rgb(var(--accent-light));
		border-radius: 4px;
		padding: 0.3em 0.4em;
	}
	.instructions strong {
		color: rgb(var(--accent-light));
	}
	.link-card-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(24ch, 1fr));
		gap: 2rem;
		padding: 0;
	}
</style>
