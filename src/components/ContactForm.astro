---
interface Props {
  accessKey?: string;
}

const { accessKey = '' } = Astro.props;
const isConfigured = !!accessKey;
---

<div class="relative w-full">
  <div class="relative bg-slate-900/40 backdrop-blur-md border border-white/5 rounded-2xl p-6 md:p-10 shadow-2xl overflow-hidden font-poppins">
    <!-- Configuration Warning (if access key is missing) -->
    {
      !isConfigured && (
        <div class="mb-8 p-6 bg-orange-500/10 border border-orange-500/30 text-orange-200 text-base rounded-xl flex flex-col gap-3 font-mono">
          <span class="font-bold flex items-center gap-2 text-lg">
            ⚠️ SYSTEM ALERT: FORM IN SANDBOX MODE
          </span>
          <p>
            Access key missing. Update <code>.env</code> to enable transmission:
          </p>
          <pre class="bg-black/40 p-3 rounded-lg text-sm overflow-x-auto text-orange-100">WEB3FORMS_ACCESS_KEY=your-access-key-here</pre>
        </div>
      )
    }

    <!-- Form Container -->
    <form id="contact-form" class="space-y-8" novalidate>
      <input type="hidden" name="access_key" value={accessKey || 'YOUR_ACCESS_KEY_HERE'} />
      <input type="hidden" name="subject" value="New Contact Form Submission - Software Smith" />
      <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Name Field -->
        <div class="space-y-3">
          <label for="contact-name" class="block text-sm font-mono font-bold text-slate-400 uppercase tracking-widest">Client // Name</label>
          <input
            type="text"
            name="name"
            id="contact-name"
            required
            class="w-full bg-black/40 border border-white/10 text-white text-lg rounded-xl px-5 py-4 placeholder-slate-600 focus:outline-none focus:border-slate-400 focus:ring-1 focus:ring-slate-400/50 transition-all duration-300"
            placeholder="John Doe"
          />
          <p id="error-name" class="text-rose-500 text-sm font-mono hidden">ERR: NAME_REQUIRED</p>
        </div>

        <!-- Email Field -->
        <div class="space-y-3">
          <label for="contact-email" class="block text-sm font-mono font-bold text-slate-400 uppercase tracking-widest">Client // Email</label>
          <input
            type="email"
            name="email"
            id="contact-email"
            required
            class="w-full bg-black/40 border border-white/10 text-white text-lg rounded-xl px-5 py-4 placeholder-slate-600 focus:outline-none focus:border-slate-400 focus:ring-1 focus:ring-slate-400/50 transition-all duration-300"
            placeholder="john@example.com"
          />
          <p id="error-email" class="text-rose-500 text-sm font-mono hidden">ERR: INVALID_EMAIL</p>
        </div>
      </div>

      <!-- Message Field -->
      <div class="space-y-3">
        <label for="contact-message" class="block text-sm font-mono font-bold text-slate-400 uppercase tracking-widest">Project // Specifications</label>
        <textarea
          name="message"
          id="contact-message"
          required
          rows="5"
          class="w-full bg-black/40 border border-white/10 text-white text-lg rounded-xl px-5 py-4 placeholder-slate-600 focus:outline-none focus:border-slate-400 focus:ring-1 focus:ring-slate-400/50 transition-all duration-300 resize-y"
          placeholder="Describe the build requirements..."
        ></textarea>
        <p id="error-message" class="text-rose-500 text-sm font-mono hidden">ERR: SPEC_REQUIRED</p>
      </div>

      <!-- Spam Protection (hCaptcha) -->
      <div class="flex flex-col items-start py-2 gap-3">
        <div class="h-captcha" data-captcha="true"></div>
        <p id="error-captcha" class="text-rose-500 text-sm font-mono hidden">ERR: CAPTCHA_FAILED</p>
      </div>

      <!-- Submit Button -->
      <div class="relative w-fit">
        <button
          type="submit"
          id="contact-submit"
          class="relative w-full md:w-fit flex items-center justify-center py-4 px-10 rounded-xl text-white text-lg font-bold bg-gradient-ember transition-all duration-300 cursor-pointer shadow-xl overflow-visible active:scale-95 active:brightness-150"
        >
          Initiate Build
        </button>
        <div id="form-spark-container" class="absolute inset-0 -z-10 pointer-events-none"></div>
      </div>
    </form>

    <!-- Success Message Container -->
    <div id="contact-success" class="hidden py-8 space-y-6">
      <div class="inline-flex items-center justify-center w-20 h-20 bg-emerald-500/10 border border-emerald-500/30 rounded-2xl text-emerald-400">
        <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <div class="space-y-2">
        <h3 class="text-3xl font-bold text-white">Transmission Successful.</h3>
        <p class="text-slate-200 text-xl max-w-lg leading-relaxed">
          Your project specifications have been received. The Forge is heating up—I'll get back to you soon.
        </p>
      </div>
      <button
        type="button"
        id="contact-reset"
        class="text-base font-mono font-bold text-slate-400 hover:text-white transition-colors duration-200 underline uppercase tracking-widest cursor-pointer"
      >
        Re-Initiate Transmission
      </button>
    </div>

    <!-- General Error message -->
    <div id="contact-error" class="hidden mt-6 p-5 bg-rose-500/10 border border-rose-500/30 text-rose-200 text-base rounded-xl font-mono">
      CRITICAL_ERROR: Failed to transmit data. Please verify network protocols or try again.
    </div>
  </div>
</div>

<script is:inline src="https://web3forms.com/client/script.js" async defer></script>

<style>
  .bg-gradient-ember {
    background-image: var(--accent-gradient-red);
    background-size: 400%;
    background-position: 0%;
    /* Constant slow red glow */
    animation: glow-pulse 4s ease-in-out infinite;
  }
  .bg-gradient-ember:hover {
    background-position: 100%;
  }

  @keyframes glow-pulse {
    0%, 100% { 
      box-shadow: 0 0 15px rgba(239, 68, 68, 0.3), inset 0 0 10px rgba(239, 68, 68, 0.2);
    }
    50% { 
      box-shadow: 0 0 25px rgba(239, 68, 68, 0.5), inset 0 0 20px rgba(239, 68, 68, 0.4);
    }
  }

  #contact-submit:active {
    transition: none;
    box-shadow: 0 0 50px rgba(251, 146, 60, 0.8), 0 0 80px rgba(239, 68, 68, 0.6);
  }
</style>

<script>
  const initContactForm = () => {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    if (!form) return;

    // Spark logic for the submit button
    const triggerSparks = () => {
      const container = document.getElementById('form-spark-container');
      const button = document.getElementById('contact-submit');
      if (!container || !button) return;
      
      const rect = button.getBoundingClientRect();
      const count = 25;
      
      for (let i = 0; i < count; i++) {
        const spark = document.createElement('div');
        spark.className = 'spark';
        
        const edge = Math.floor(Math.random() * 4);
        let x, y, tx, ty;
        const distance = 100 + Math.random() * 200;
        
        if (edge === 0) { // Top
          x = Math.random() * rect.width;
          y = 0;
          tx = (x - rect.width / 2) + (Math.random() - 0.5) * 100 + 'px';
          ty = -distance + 'px';
        } else if (edge === 1) { // Right
          x = rect.width;
          y = Math.random() * rect.height;
          tx = distance + 'px';
          ty = (y - rect.height / 2) + (Math.random() - 0.5) * 100 + 'px';
        } else if (edge === 2) { // Bottom
          x = Math.random() * rect.width;
          y = rect.height;
          tx = (x - rect.width / 2) + (Math.random() - 0.5) * 100 + 'px';
          ty = distance + 'px';
        } else { // Left
          x = 0;
          y = Math.random() * rect.height;
          tx = -distance + 'px';
          ty = (y - rect.height / 2) + (Math.random() - 0.5) * 100 + 'px';
        }

        spark.style.left = x + 'px';
        spark.style.top = y + 'px';
        spark.style.setProperty('--tx', tx);
        spark.style.setProperty('--ty', ty);
        
        container.appendChild(spark);
        setTimeout(() => spark.remove(), 600);
      }
    };

    const successMessage = document.getElementById('contact-success');
    const errorMessage = document.getElementById('contact-error');
    const resetButton = document.getElementById('contact-reset') as HTMLButtonElement;

    const submitButton = document.getElementById('contact-submit') as HTMLButtonElement;
    
    // Attach spark effect to click
    submitButton.addEventListener('mousedown', triggerSparks);
    submitButton.addEventListener('touchstart', triggerSparks, { passive: true });

    // Fields
    const fields = {
      name: {
        input: document.getElementById('contact-name') as HTMLInputElement,
        error: document.getElementById('error-name')
      },
      email: {
        input: document.getElementById('contact-email') as HTMLInputElement,
        error: document.getElementById('error-email')
      },
      message: {
        input: document.getElementById('contact-message') as HTMLTextAreaElement,
        error: document.getElementById('error-message')
      },
      captcha: {
        error: document.getElementById('error-captcha')
      }
    };

    const isValidEmail = (email: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);

    const validateForm = (formData: FormData) => {
      let isValid = true;
      if (!fields.name.input.value.trim()) {
        fields.name.error?.classList.remove('hidden');
        fields.name.input.classList.add('border-rose-500');
        isValid = false;
      } else {
        fields.name.error?.classList.add('hidden');
        fields.name.input.classList.remove('border-rose-500');
      }

      if (!fields.email.input.value.trim() || !isValidEmail(fields.email.input.value)) {
        fields.email.error?.classList.remove('hidden');
        fields.email.input.classList.add('border-rose-500');
        isValid = false;
      } else {
        fields.email.error?.classList.add('hidden');
        fields.email.input.classList.remove('border-rose-500');
      }

      if (!fields.message.input.value.trim()) {
        fields.message.error?.classList.remove('hidden');
        fields.message.input.classList.add('border-rose-500');
        isValid = false;
      } else {
        fields.message.error?.classList.add('hidden');
        fields.message.input.classList.remove('border-rose-500');
      }

      const captchaResponse = formData.get('h-captcha-response');
      if (!captchaResponse) {
        fields.captcha.error?.classList.remove('hidden');
        isValid = false;
      } else {
        fields.captcha.error?.classList.add('hidden');
      }
      return isValid;
    };

    [fields.name, fields.email, fields.message].forEach((field) => {
      field.input.addEventListener('input', () => {
        field.error?.classList.add('hidden');
        field.input.classList.remove('border-rose-500');
      });
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      if (!validateForm(formData)) return;

      submitButton.disabled = true;
      const originalText = submitButton.innerHTML;
      submitButton.innerHTML = `TRANSMITTING...`;
      errorMessage?.classList.add('hidden');

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData
        });
        const result = await response.json();
        if (response.ok && result.success) {
          form.reset();
          // @ts-ignore
          if (window.hcaptcha) window.hcaptcha.reset();
          form.classList.add('hidden');
          successMessage?.classList.remove('hidden');
        } else {
          throw new Error(result.message || 'Failed to submit form');
        }
      } catch (error) {
        errorMessage?.classList.remove('hidden');
      } finally {
        submitButton.disabled = false;
        submitButton.innerHTML = originalText;
      }
    });

    resetButton?.addEventListener('click', () => {
      successMessage?.classList.add('hidden');
      form.classList.remove('hidden');
    });
  };

  initContactForm();
  document.addEventListener('astro:after-swap', initContactForm);
</script>
