---

---

<footer class="group mx-auto mt-32 w-full max-w-7xl px-4 pb-16">
  <div
    class="h-1px relative mb-12 w-full overflow-hidden bg-linear-to-r from-transparent via-slate-700/50 to-transparent"
  >
    <div
      class="group-hover:animate-shimmer absolute inset-0 -translate-x-full bg-linear-to-r from-transparent via-white/10 to-transparent"
    >
    </div>
  </div>

  <div
    class="flex flex-col items-center justify-between gap-8 text-center md:flex-row md:text-left"
  >
    <div class="flex flex-col gap-2">
      <p class="font-mono text-xs tracking-[0.2em] text-slate-500 uppercase">
        Built // 2026
      </p>
      <p class="font-medium text-slate-300">
        Forged in the <span class="text-gradient-steel font-bold italic"
          >Digital Foundry</span
        > by The Software Smith.
      </p>
    </div>

    <div class="flex flex-col gap-4 md:items-end">
      <p class="font-mono text-xs tracking-[0.2em] text-slate-500 uppercase">
        Tooling & Specifications
      </p>
      <div
        class="flex flex-wrap items-center justify-center gap-8 md:justify-end"
      >
        <!-- Astro -->
        <div class="group/tech relative" title="Astro">
          <img
            src="/astro-svgrepo-com.svg"
            alt="Astro"
            class="h-10 w-10 brightness-75 grayscale transition-all duration-300 group-hover/tech:brightness-110 group-hover/tech:drop-shadow-[0_0_10px_rgba(255,93,1,0.3)] group-hover/tech:grayscale-0"
          />
        </div>
        <!-- Tailwind -->
        <div class="group/tech relative" title="Tailwind CSS">
          <img
            src="/tailwind-svgrepo-com.svg"
            alt="Tailwind CSS"
            class="h-10 w-10 brightness-75 grayscale transition-all duration-300 group-hover/tech:brightness-110 group-hover/tech:drop-shadow-[0_0_10px_rgba(56,189,248,0.3)] group-hover/tech:grayscale-0"
          />
        </div>
        <!-- TypeScript -->
        <div class="group/tech relative" title="TypeScript">
          <img
            src="/typescript-svgrepo-com.svg"
            alt="TypeScript"
            class="h-10 w-10 brightness-75 grayscale transition-all duration-300 group-hover/tech:brightness-110 group-hover/tech:drop-shadow-[0_0_10px_rgba(49,120,198,0.3)] group-hover/tech:grayscale-0"
          />
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .text-gradient-steel {
    background-image: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  @keyframes shimmer {
    100% {
      transform: translateX(100%);
    }
  }

  .animate-shimmer {
    animation: shimmer 2s infinite ease-in-out;
  }
</style>
