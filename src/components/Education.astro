---
import EducationCard from "./EducationCard.astro";
import SectionHeader from "./SectionHeader.astro";
import education from "../data/education.json";
---

<section
  id="education"
  class="mx-auto mt-24 flex w-full max-w-7xl scroll-mt-24 flex-col items-start justify-center gap-12 px-4"
>
  <SectionHeader index="02" title="Academic Credentials" gradient="steel" />

  <div class="flex w-full flex-col gap-8">
    {
      education.map((item) => (
        <EducationCard
          degree={item.degree}
          institution={item.institution}
          location={item.location}
          date={item.date}
          gpa={item.gpa}
          focus={item.focus}
        />
      ))
    }
  </div>
</section>
