---
interface Props {
  degree: string;
  institution: string;
  location: string;
  date: string;
  gpa: string;
  focus: string;
}

const { degree, institution, location, date, gpa, focus } = Astro.props;
---

<div class="w-full bg-slate-900/40 backdrop-blur-md border border-white/5 rounded-2xl p-6 md:p-10 hover:border-white/10 hover:shadow-2xl transition-all duration-300">
  <div class="flex flex-col md:flex-row md:justify-between md:items-baseline gap-4 mb-6">
    <div class="flex flex-col gap-1">
      <h3 class="text-3xl font-bold text-white tracking-tight">
        {degree}
      </h3>
      <p class="text-xl font-semibold text-slate-400">
        {institution} <span class="text-slate-600 font-normal">// {location}</span>
      </p>
    </div>
    <div class="flex flex-col md:items-end gap-2">
      <span class="text-base font-bold text-slate-300 bg-white/5 px-4 py-1.5 rounded-lg border border-white/10 w-fit tabular-nums">
        {date}
      </span>
      <span class="text-sm font-mono font-bold text-gradient-steel uppercase tracking-widest">
        Grade: {gpa}
      </span>
    </div>
  </div>
  <div class="flex flex-col gap-4 mt-6">
    <div class="h-[1px] w-12 bg-slate-700"></div>
    <p class="text-lg md:text-xl text-slate-200 leading-relaxed font-medium">
      {focus}
    </p>
  </div>
</div>

<style>
  .text-gradient-steel {
    background-image: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>
