---
interface Props {
  degree: string;
  institution: string;
  location: string;
  date: string;
  gpa: string;
  focus: string;
}

const { degree, institution, location, date, gpa, focus } = Astro.props;
---

<div
  class="w-full rounded-2xl border border-white/5 bg-slate-900/40 p-6 backdrop-blur-md transition-all duration-300 hover:border-white/10 hover:shadow-2xl md:p-10"
>
  <div
    class="mb-6 flex flex-col gap-4 md:flex-row md:items-baseline md:justify-between"
  >
    <div class="flex flex-col gap-1">
      <h3 class="text-3xl font-bold tracking-tight text-white">
        {degree}
      </h3>
      <p class="text-xl font-semibold text-slate-400">
        {institution}
        <span class="font-normal text-slate-600">// {location}</span>
      </p>
    </div>
    <div class="flex flex-col gap-2 md:items-end">
      <span
        class="w-fit rounded-lg border border-white/10 bg-white/5 px-4 py-1.5 text-base font-bold text-slate-300 tabular-nums"
      >
        {date}
      </span>
      <span
        class="text-gradient-steel font-mono text-sm font-bold tracking-widest uppercase"
      >
        Grade: {gpa}
      </span>
    </div>
  </div>
  <div class="mt-6 flex flex-col gap-4">
    <div class="h-[1px] w-12 bg-slate-700"></div>
    <p class="text-lg leading-relaxed font-medium text-slate-200 md:text-xl">
      {focus}
    </p>
  </div>
</div>

<style>
  .text-gradient-steel {
    background-image: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>
