---

<a
  href="#contact"
  id="hammer-button"
  class="bg-gradient-ember group relative inline-block cursor-pointer overflow-visible rounded-xl border border-orange-500/30 px-10 py-4 text-center font-black text-white shadow-2xl transition-all duration-300 active:scale-90 active:brightness-150"
>
  <span class="relative z-10 text-lg tracking-widest uppercase"
    >Contact the Smith</span
  >
</a>

<style>
  .bg-gradient-ember {
    background-image: var(--accent-gradient-red);
    background-size: 400%;
    background-position: 0%;
    /* Constant slow red glow */
    animation: glow-pulse 4s ease-in-out infinite;
  }

  @keyframes glow-pulse {
    0%,
    100% {
      box-shadow:
        0 0 15px rgba(239, 68, 68, 0.3),
        inset 0 0 10px rgba(239, 68, 68, 0.2);
    }
    50% {
      box-shadow:
        0 0 25px rgba(239, 68, 68, 0.5),
        inset 0 0 20px rgba(239, 68, 68, 0.4);
    }
  }

  /* Hammer strike on active */
  #hammer-button:active {
    transition: none;
    box-shadow:
      0 0 50px rgba(251, 146, 60, 0.8),
      0 0 80px rgba(239, 68, 68, 0.6);
  }
</style>
