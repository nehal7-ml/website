---
interface Props {
  title: string;
  description: string;
  startDate: string;
  endDate: string;
}

const { title, description, startDate, endDate } = Astro.props;
---

<li
  class="w-full list-none rounded-2xl border border-white/5 bg-slate-900/40 p-6 backdrop-blur-md transition-all duration-300 hover:border-white/10 hover:shadow-2xl md:p-10"
>
  <div
    class="mb-6 flex flex-col gap-4 md:flex-row md:items-baseline md:justify-between"
  >
    <h3 class="text-3xl font-bold tracking-tight text-white">
      {title}
    </h3>
    <span
      class="w-fit rounded-lg border border-white/10 bg-white/5 px-4 py-1.5 text-base font-bold text-slate-400 tabular-nums"
    >
      {startDate} — {endDate}
    </span>
  </div>
  <p class="text-lg leading-relaxed font-medium text-slate-200 md:text-xl">
    {description}
  </p>
</li>
