---
interface Props {
	title: string;
	description: string;
	startDate: string;
	endDate: string;
}

const { title, description, startDate, endDate } = Astro.props;
---

<li class="list-none w-full bg-slate-900/40 backdrop-blur-md border border-white/5 rounded-2xl p-6 md:p-10 hover:border-white/10 hover:shadow-2xl transition-all duration-300">
  <div class="flex flex-col md:flex-row md:justify-between md:items-baseline gap-4 mb-6">
    <h3 class="text-3xl font-bold text-white tracking-tight">
      {title}
    </h3>
    <span class="text-base font-bold text-slate-400 bg-white/5 px-4 py-1.5 rounded-lg border border-white/10 w-fit tabular-nums">
      {startDate} — {endDate}
    </span>
  </div>
  <p class="text-lg md:text-xl text-slate-200 leading-relaxed font-medium">
    {description}
  </p>
</li>

