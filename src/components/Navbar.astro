---
import { Menu, X } from "@lucide/astro";
import Logo from "./Logo.astro";
---

<!-- 1. The Checkbox Driver at the very top -->
<input type="checkbox" id="menu-toggle" class="peer hidden" />

<!-- 2. The Navbar (Now completely free of hidden menu layout calculations) -->
<nav
  class="sticky top-0 z-50 flex w-full items-center justify-between border-b border-white/5 bg-[#13151a]/80 px-6 py-4 backdrop-blur-md md:px-10"
>
  <a
    href="/"
    class="w-12 transition-transform duration-300 hover:scale-105 md:w-14"
  >
    <Logo height={100} width={100} />
  </a>

  <!-- Desktop Menu -->
  <ul class="hidden items-center justify-between gap-5 text-white md:flex">
    <li
      class="px-4 py-2 text-base font-bold tracking-wider uppercase transition-colors hover:text-orange-400"
    >
      <a href="#about">About</a>
    </li>
    <li
      class="px-4 py-2 text-base font-bold tracking-wider uppercase transition-colors hover:text-orange-400"
    >
      <a href="#work">Work Experience</a>
    </li>
    <li
      class="px-4 py-2 text-base font-bold tracking-wider uppercase transition-colors hover:text-orange-400"
    >
      <a href="#education">Education</a>
    </li>
    <li
      class="px-4 py-2 text-base font-bold tracking-wider uppercase transition-colors hover:text-orange-400"
    >
      <a href="#projects">Projects</a>
    </li>
    <li
      class="px-4 py-2 text-base font-bold tracking-wider uppercase transition-colors hover:text-orange-400"
    >
      <a href="#contact">Contact</a>
    </li>
  </ul>

  <!-- Toggle Button for Mobile -->
  <label for="menu-toggle" class="z-60 block cursor-pointer p-2 md:hidden">
    <div class="peer-checked:hidden">
      <Menu class="text-gray-300" />
    </div>
  </label>
</nav>

<!-- 3. The Mobile Menu (Moved completely OUTSIDE the nav as a sibling to the peer checkbox) -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 flex min-h-screen translate-x-full flex-col items-center justify-center gap-8 bg-[#13151a] transition-transform duration-500 peer-checked:translate-x-0 md:hidden"
>
  <!-- Close Button inside the menu overlay -->
  <label for="menu-toggle" class="absolute top-6 right-6 cursor-pointer p-2">
    <X class="text-gray-300" />
  </label>

  <ul class="flex flex-col items-center gap-10 text-white">
    <li
      class="text-3xl font-black tracking-[0.2em] uppercase transition-colors hover:text-orange-500"
    >
      <a
        href="#about"
        onclick="document.getElementById('menu-toggle').checked = false"
        >About</a
      >
    </li>
    <li
      class="text-3xl font-black tracking-[0.2em] uppercase transition-colors hover:text-orange-500"
    >
      <a
        href="#work"
        onclick="document.getElementById('menu-toggle').checked = false"
        >Work Experience</a
      >
    </li>
    <li
      class="text-3xl font-black tracking-[0.2em] uppercase transition-colors hover:text-orange-500"
    >
      <a
        href="#education"
        onclick="document.getElementById('menu-toggle').checked = false"
        >Education</a
      >
    </li>
    <li
      class="text-3xl font-black tracking-[0.2em] uppercase transition-colors hover:text-orange-500"
    >
      <a
        href="#projects"
        onclick="document.getElementById('menu-toggle').checked = false"
        >Projects</a
      >
    </li>
    <li
      class="text-3xl font-black tracking-[0.2em] uppercase transition-colors hover:text-orange-500"
    >
      <a
        href="#contact"
        onclick="document.getElementById('menu-toggle').checked = false"
        >Contact</a
      >
    </li>
  </ul>
</div>
