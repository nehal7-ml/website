---
import { getSecret } from "astro:env/server";
import socials from "../data/socials.json";
import ContactForm from "./ContactForm.astro";
import SectionHeader from "./SectionHeader.astro";
const web3formsAccessKey = getSecret("WEB3FORMS_ACCESS_KEY") || "";
---

<section
  id="contact"
  class="mx-auto mt-24 mb-16 flex w-full max-w-7xl scroll-mt-24 flex-col items-center justify-center gap-8 px-4"
>
  <SectionHeader index="04" title="Contact Me" gradient="steel" />
  <!-- Subtle Background Heat Glow -->
  <div
    class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(circle_at_center,rgba(249,115,22,0.08)_0%,transparent_70%)]"
  >
  </div>

  <!-- Section Header modeled after an artisan stamp -->
  <div class="mb-8 text-center">
    <h3
      class="text-xl font-bold tracking-wide text-slate-200 uppercase sm:text-2xl"
    >
      Professional Networks
    </h3>
    <p class="mx-auto mt-1 max-w-sm text-xs tracking-wide text-slate-400">
      Available for freelance commissions and full-scale development contracts
      through verified platforms.
    </p>
  </div>
  <div class="mx-auto grid max-w-3xl grid-cols-1 gap-4 p-6 sm:grid-cols-3">
    {
      socials.map((profile) => (
        <a
          href={profile.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center justify-between rounded-lg border border-slate-400 p-5 transition-all duration-200 hover:border-orange-500/40 hover:bg-slate-800"
        >
          <div class="flex items-center gap-3">
            <img
              src={profile.logo}
              class="h-16 w-16 object-contain"
              alt={profile.name}
            />

            <span class="text-sm font-semibold tracking-wide text-slate-300 transition-colors duration-200 group-hover:text-white">
              {profile.name}
            </span>
          </div>
        </a>
      ))
    }
  </div>

  <span class="flex items-center justify-center gap-2 text-center">
    <hr class="w-full border-t border-slate-400/50" />
    Or
    <hr class="w-full border-t border-slate-400/50" />
  </span>
  <div class="w-full">
    <ContactForm accessKey={web3formsAccessKey} />
  </div>
</section>
